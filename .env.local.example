# Environment Variables Template
# Copy this file to .env.local and fill in your values

# =============================================================================
# Application Insights Configuration
# =============================================================================

# Server-side telemetry (Node.js SDK)
# Get this from Azure Portal > Application Insights > Overview > Connection String
# Required for server-side logging (middleware, API routes, server components)
APPLICATIONINSIGHTS_CONNECTION_STRING=your-connection-string-here

# Client-side telemetry (Browser SDK)
# Same connection string as above, but with NEXT_PUBLIC_ prefix to expose to browser
# Required for client-side logging (client components, browser errors, page views)
NEXT_PUBLIC_APPLICATIONINSIGHTS_CONNECTION_STRING=your-connection-string-here

# =============================================================================
# How to Get Your Connection String
# =============================================================================
# 1. Go to Azure Portal: https://portal.azure.com
# 2. Navigate to your Application Insights resource (or create a new one)
# 3. In the Overview section, copy the "Connection String"
# 4. Paste it into both variables above
#
# The connection string looks like:
# InstrumentationKey=12345678-1234-1234-1234-123456789abc;IngestionEndpoint=https://...
#
# Note: Both server and client use the same connection string

# =============================================================================
# Google Calendar API Configuration
# =============================================================================

# Google Calendar API credentials. Follow the setup steps in
# docs/google-calendar-setup.md.
#
# Two separate OAuth identities are referenced below:
#   1. Server-only:  GOOGLE_CLIENT_ID + GOOGLE_CLIENT_SECRET
#      Read by NextAuth and the /api/auth/refresh-token route. Unprefixed
#      so Next.js does NOT inline these into the browser bundle.
#   2. Browser-only: NEXT_PUBLIC_GOOGLE_CLIENT_ID + NEXT_PUBLIC_GOOGLE_API_KEY
#      Read by the legacy client-side gapi/GIS flow in
#      `src/lib/google-calendar.ts`. The `NEXT_PUBLIC_` prefix is required
#      because the value is consumed in the browser. New server-side code
#      MUST NOT read these — use the unprefixed pair instead.
#
# In practice the same OAuth 2.0 Client ID can be used for both pairs while
# the legacy client-side flow exists.

# Server-side OAuth Client ID (used by NextAuth + token refresh)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Server-side OAuth Client Secret (REQUIRED for token refresh functionality)
# IMPORTANT: Keep this secret! Never commit to source control.
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Browser-side OAuth Client ID (legacy gapi/GIS flow only)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Browser-side API Key (legacy gapi/GIS flow only)
# Create in Google Cloud Console > APIs & Services > Credentials
NEXT_PUBLIC_GOOGLE_API_KEY=your-google-api-key

# =============================================================================
# NextAuth.js (Auth.js v5) — Session signing secret
# =============================================================================

# Used by NextAuth (v5) to sign session cookies. AUTH_SECRET is the v5
# canonical name; NEXTAUTH_SECRET is the v4 name and is still accepted as
# a fallback. Generate with: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-here

# =============================================================================
# Token Encryption (OAuth tokens at rest)
# =============================================================================

# AES-256-GCM key for encrypting Google OAuth access/refresh/id tokens at
# rest in the PostgreSQL `Account` table. Must decode to exactly 32 bytes.
# Generate with: openssl rand -base64 32
#
# REQUIRED in production. In development, the cipher falls back to a key
# derived (HKDF) from AUTH_SECRET (or NEXTAUTH_SECRET) so local setup stays
# simple — but rotating the source secret invalidates every encrypted token,
# so set this explicitly for any shared/persistent dev or staging
# environment.
#
# Without either AUTH_SECRET / NEXTAUTH_SECRET *and* without
# TOKEN_ENCRYPTION_KEY, the auth module fails fast at boot rather than
# degrading silently to "Session expired" 401s on every request (see #315).
TOKEN_ENCRYPTION_KEY=your-token-encryption-key-here

# =============================================================================
# Other Configuration (Optional)
# =============================================================================

# Node environment (automatically set by Next.js)
# NODE_ENV=development

# Next.js public API endpoint (if needed)
# NEXT_PUBLIC_API_ENDPOINT=https://api.example.com/api
